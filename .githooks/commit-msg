#!/usr/bin/env bash
set -euo pipefail

message_file=$1
subject=$(head -n 1 "$message_file")
pattern='^(feat|fix|data|docs|test|refactor|perf|build|ci|chore|revert)(\([a-z0-9][a-z0-9._-]*\))?!?: .+'

if [[ "$subject" == Merge\ * || "$subject" == Revert\ \"* ]]; then
    exit 0
fi

if (( ${#subject} > 72 )); then
    echo "提交标题不能超过72个字符。" >&2
    exit 1
fi

if [[ ! "$subject" =~ $pattern ]]; then
    cat >&2 <<'EOF'
提交说明格式不正确。

要求格式：type(scope): 清晰的中文描述
示例：feat(screening): 增加流动性筛选规则

允许的type：feat、fix、data、docs、test、refactor、perf、build、ci、chore、revert
EOF
    exit 1
fi

description=${subject#*: }
description_lower=${description,,}

if (( ${#description} < 6 )); then
    echo "提交描述至少需要6个字符。" >&2
    exit 1
fi

if [[ "$description" == *. ]]; then
    echo "提交标题末尾不能使用句号。" >&2
    exit 1
fi

if ! printf '%s\n' "$description" | grep -Pq '\p{Han}'; then
    echo "提交描述必须使用中文。" >&2
    exit 1
fi

case "$description_lower" in
    "更新文件" | "修复问题" | "其他修改" | "临时修改" | "调整代码" | "修改内容")
        echo "提交描述过于模糊，必须明确实际动作和对象。" >&2
        exit 1
        ;;
esac

if [[ "$subject" =~ ^[^:]+!: ]] && ! grep -Eq '^BREAKING CHANGE: .+' "$message_file"; then
    echo "不兼容变更必须包含'BREAKING CHANGE:'页脚。" >&2
    exit 1
fi
